<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.mc.esinfo.mapper.LogMapper">
    <resultMap type="com.mc.escommon.entity.info.Log" id="LogResult">
        <result property="id" column="id"/>
        <result property="userId" column="userId"/>
        <result property="role" column="role"/>
        <result property="username" column="username"/>
        <result property="name" column="name"/>
        <result property="time" column="time"/>
        <result property="ip" column="ip"/>
    </resultMap>

    <sql id="selectLogVo">
        select id, userId, username, role, name, time, ip
        from system_log
    </sql>
    <!--    增加-->
    <insert id="insert" parameterType="com.mc.escommon.entity.info.Log" useGeneratedKeys="true" keyProperty="id">
        insert into system_log
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="userId != null and userId !='' ">userId,</if>
            <if test="role != null and role !='' ">role,</if>
            <if test="username != null and username !='' ">username,</if>
            <if test="name != null and name !='' ">name,</if>
            <if test="time != null and time !='' ">time,</if>
            <if test="ip != null and ip !='' ">ip,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="userId != null and userId !=''">#{userId},</if>
            <if test="role != null and role !=''">#{role},</if>
            <if test="username != null and username !=''">#{username},</if>
            <if test="name != null and name !='' ">#{name},</if>
            <if test="time != null and time !=''">#{time},</if>
            <if test="ip != null and ip !=''">#{ip},</if>
        </trim>
    </insert>

    <!--    单个删除-->
    <delete id="deleteById" parameterType="int">
        delete from system_log where id=#{id}
    </delete>
    <!--    批量删除-->
    <delete id="deleteByIds" parameterType="int">
        delete from system_log where id in
        <foreach collection="array" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    <!--    根据条件查找-->
    <select id="selectAll" parameterType="com.mc.escommon.entity.info.Log" resultMap="LogResult">
        <include refid="selectLogVo"/>
        <where>
            <if test="id != null">
                AND id = #{id}
            </if>
            <if test="userId != null and userId != ''">
                AND userId =#{userId}
            </if>
            <if test="role != null and role != ''">
                AND role like concat('%',#{role},'%')
            </if>
            <if test="username != null and username != ''">
                AND username like concat('%',#{username},'%')
            </if>
            <if test="name != null and name != ''">
                AND name like concat('%',#{name},'%')
            </if>
            <if test="time != null and time != ''">
                AND time = #{time}
            </if>
            <if test="ip != null and ip != ''">
                AND ip = #{ip}
            </if>
        </where>
    </select>

    <!--    根据id查询-->
    <select id="selectById" parameterType="com.mc.escommon.entity.info.Log" resultMap="LogResult">
        <include refid="selectLogVo"/>
        where id = #{id}
    </select>

    <!--    修改-->
    <update id="updateById" parameterType="com.mc.escommon.entity.info.Log">
        update system_log
        <set>
            <if test="userId != null and userId != ''">userId = #{userId},</if>
            <if test="role != null and role != ''">role = #{role},</if>
            <if test="username != null and username != ''">username = #{username},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="time != null and time != ''">time = #{time},</if>
            <if test="ip != null and ip != ''">ip = #{ip},</if>
        </set>
        where id = #{id}
    </update>
</mapper>