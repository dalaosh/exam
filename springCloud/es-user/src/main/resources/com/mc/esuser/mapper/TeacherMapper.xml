<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.mc.esuser.mapper.TeacherMapper">
    <resultMap type="com.mc.escommon.entity.user.Teacher" id="TeacherResult">
        <result property="id" column="id"/>
        <result property="role" column="role"/>
        <result property="photo" column="photo"/>
        <result property="account" column="account"/>
        <result property="password" column="password"/>
        <result property="keySm3" column="key_sm3"/>
        <result property="email" column="email"/>
        <result property="name" column="name"/>
        <result property="sex" column="sex"/>
        <result property="phone" column="phone"/>
        <result property="publicKey" column="public_key"/>
    </resultMap>

    <sql id="selectTeacherVo">
        select id, role, photo, account, password, key_sm3, email, name, sex, phone, public_key
        from teacher
    </sql>
    <!--    增加-->
    <insert id="insert" parameterType="com.mc.escommon.entity.user.Teacher" useGeneratedKeys="true" keyProperty="id">
        insert into teacher
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="role != null and role !='' ">role,</if>
            <if test="photo != null and photo !='' ">photo,</if>
            <if test="account != null and account !='' ">account,</if>
            <if test="password != null and password !='' ">password,</if>
            <if test="keySm3 != null and keySm3 !='' ">key_sm3,</if>
            <if test="email != null and email !='' ">email,</if>
            <if test="name != null and name !='' ">name,</if>
            <if test="sex != null and sex !='' ">sex,</if>
            <if test="phone != null and phone !='' ">phone,</if>
            <if test="publicKey != null and publicKey !='' ">public_key,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="role != null and role !='' ">#{role},</if>
            <if test="photo != null and photo !=''">#{photo},</if>
            <if test="account != null and account !=''">#{account},</if>
            <if test="password != null and password !=''">#{password},</if>
            <if test="keySm3 != null and keySm3 !='' ">#{keySm3},</if>
            <if test="email != null and email !=''">#{email},</if>
            <if test="name != null and name !=''">#{name},</if>
            <if test="sex != null and sex !=''">#{sex},</if>
            <if test="phone != null and phone !=''">#{phone},</if>
            <if test="publicKey != null and publicKey !=''">#{publicKey},</if>
        </trim>
    </insert>

    <!--    单个删除-->
    <delete id="deleteById" parameterType="int">
        delete from teacher where id=#{id}
    </delete>
    <!--    批量删除-->
    <delete id="deleteByIds" parameterType="int">
        delete from teacher where id in
        <foreach collection="array" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
    <!--    根据条件查找-->
    <select id="selectAll" parameterType="com.mc.escommon.entity.user.Teacher" resultMap="TeacherResult">
        <include refid="selectTeacherVo"/>
        <where>
            <if test="id != null">
                AND id = #{id}
            </if>
            <if test="role != null and role != ''">
                AND role = #{role}
            </if>
            <if test="photo != null and photo != ''">
                AND photo = #{photo}
            </if>
            <if test="account != null and account != ''">
                AND account = #{account}
            </if>
            <if test="password != null and password != ''">
                AND password = #{password}
            </if>
            <if test="keySm3 != null and keySm3 != ''">
                AND key_sm3 = #{keySm3}
            </if>
            <if test="email != null and email != ''">
                AND email = #{email}
            </if>
            <if test="name != null and name != ''">
                AND name like concat('%',#{name},'%')
            </if>
            <if test="sex != null and sex != ''">
                AND sex = #{sex}
            </if>
            <if test="phone != null and phone != ''">
                AND phone = #{phone}
            </if>
            <if test="publicKey != null and publicKey != ''">
                AND public_key = #{publicKey}
            </if>
        </where>
    </select>

    <!--    根据id查询-->
    <select id="selectById" parameterType="com.mc.escommon.entity.user.Teacher" resultMap="TeacherResult">
        <include refid="selectTeacherVo"/>
        where id = #{id}
    </select>
    <select id="findByAccountAndPassword" parameterType="com.mc.escommon.entity.user.Teacher" resultMap="TeacherResult">
        <include refid="selectTeacherVo"/>
        where account=#{account} and password =#{password}
    </select>
    <select id="selectByAccountAndPhone" parameterType="com.mc.escommon.entity.user.Teacher" resultMap="TeacherResult">
        <include refid="selectTeacherVo"/>
        where account=#{account} and phone =#{phone}
    </select>
    <select id="findByAccountAndSM3" parameterType="com.mc.escommon.entity.user.Teacher" resultMap="TeacherResult">
        <include refid="selectTeacherVo"/>
        where account=#{account} and key_sm3 =#{keySm3}
    </select>
    <!--    修改-->
    <update id="updateById" parameterType="com.mc.escommon.entity.user.Teacher">
        update teacher
        <set>
            <if test="photo != null and photo != ''">photo = #{photo},</if>
            <if test="account != null and account != ''">account = #{account},</if>
            <if test="password != null and password != ''">password = #{password},</if>
            <if test="keySm3 != null and keySm3 != ''">key_sm3 = #{keySm3},</if>
            <if test="email != null and email != ''">email = #{email},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="sex != null and sex != ''">sex = #{sex},</if>
            <if test="phone != null and phone != ''">phone = #{phone},</if>
            <if test="publicKey != null and publicKey != ''">public_key = #{publicKey},</if>
        </set>
        where id = #{id}
    </update>
</mapper>