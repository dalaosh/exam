<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.mc.esexam.mapper.CodeMapper">
    <resultMap id="Code" type="com.mc.escommon.entity.exam.Code">
        <!-- 映射 Code 实体类自身的属性 -->
        <result property="id" column="id"/>
        <result property="studentId" column="student_id"/>
        <result property="time" column="time"/>
        <result property="title" column="title"/>
        <result property="type" column="type"/>
        <result property="codeMessage" column="codeMessage"/>
        <result property="runMessage" column="runMessage"/>

        <!-- 关联映射 Student 对象的属性 -->
        <association property="student" javaType="com.mc.escommon.entity.user.Student">
            <result property="id" column="student_id"/>
            <result property="role" column="role"/>
            <result property="photo" column="student_photo"/>
            <result property="account" column="account"/>
            <result property="password" column="password"/>
            <result property="keySm3" column="key_sm3"/>
            <result property="email" column="email"/>
            <result property="name" column="student_name"/>
            <result property="sex" column="sex"/>
            <result property="phone" column="phone"/>
            <result property="publicKey" column="public_key"/>
        </association>
    </resultMap>

    <sql id="selectVo">
        SELECT
            c.id,
            c.student_id,
            c.time,
            c.title,
            c.type,
            c.codeMessage,
            c.runMessage,
            s.id AS student_id,
            s.role,
            s.photo AS student_photo,
            s.account,
            s.password,
            s.key_sm3,
            s.email,
            s.name AS student_name,
            s.sex,
            s.phone,
            s.public_key
        FROM
            code c
                LEFT JOIN
            student s ON c.student_id = s.id
    </sql>

    <insert id="insert" parameterType="com.mc.escommon.entity.exam.Code" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO code
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="studentId != null">student_id,</if>
            <if test="time != null">time,</if>
            <if test="title != null and title != ''">title,</if>
            <if test="type != null">type,</if>
            <if test="codeMessage != null and codeMessage != ''">codeMessage,</if>
            <if test="runMessage != null and runMessage != ''">runMessage</if>
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="studentId != null">#{studentId},</if>
            <if test="time != null">#{time},</if>
            <if test="title != null and title != ''">#{title},</if>
            <if test="type != null">#{type},</if>
            <if test="codeMessage != null and codeMessage != ''">#{codeMessage},</if>
            <if test="runMessage != null and runMessage != ''">#{runMessage}</if>
        </trim>
    </insert>

    <!-- 单个删除 -->
    <delete id="deleteById" parameterType="int">
        DELETE FROM code WHERE id = #{id}
    </delete>

    <!-- 批量删除 -->
    <delete id="deleteByIds" parameterType="int[]">
        DELETE FROM code WHERE id IN
        <foreach collection="array" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="selectAll" parameterType="com.mc.escommon.entity.exam.Code" resultMap="Code">
        <!-- 引入之前定义的 SQL 片段 -->
        <include refid="selectVo"/>
        <!-- 使用 where 标签来动态生成 WHERE 子句 -->
        <where>
            <!-- 判断 id 是否不为空，如果不为空则添加对应的查询条件 -->
            <if test="id != null">
                AND c.id = #{id} <!-- 使用表别名 c 引用 id 列 -->
            </if>
            <!-- 判断 studentId 是否不为空，如果不为空则添加对应的查询条件 -->
            <if test="studentId != null">
                AND c.student_id = #{studentId} <!-- 使用表别名 c 引用 student_id 列 -->
            </if>
            <!-- 判断 time 是否不为空，如果不为空则添加对应的查询条件 -->
            <if test="time != null">
                AND c.time = #{time} <!-- 使用表别名 c 引用 time 列 -->
            </if>
            <!-- 判断 title 是否不为空且不为空字符串，如果满足条件则添加对应的查询条件 -->
            <if test="title != null and title != ''">
                AND c.title = #{title} <!-- 使用表别名 c 引用 title 列 -->
            </if>
            <!-- 判断 type 是否不为空，如果不为空则添加对应的查询条件 -->
            <if test="type != null">
                AND c.type = #{type} <!-- 使用表别名 c 引用 type 列 -->
            </if>
            <!-- 判断 codeMessage 是否不为空且不为空字符串，如果满足条件则添加对应的查询条件 -->
            <if test="codeMessage != null and codeMessage != ''">
                AND c.codeMessage = #{codeMessage} <!-- 使用表别名 c 引用 codeMessage 列 -->
            </if>
            <!-- 判断 runMessage 是否不为空且不为空字符串，如果满足条件则添加对应的查询条件 -->
            <if test="runMessage != null and runMessage != ''">
                AND c.runMessage = #{runMessage} <!-- 使用表别名 c 引用 runMessage 列 -->
            </if>
        </where>
        ORDER BY c.time DESC
    </select>

    <select id="selectById" parameterType="int" resultMap="Code">
        <!-- 引入之前定义的查询代码相关信息的 SQL 片段 -->
        <include refid="selectVo"/>
        <!-- 根据代码的唯一标识 id 进行筛选 -->
        WHERE c.id = #{id}
        ORDER BY c.time DESC
    </select>

    <select id="selectByStudentId" parameterType="int" resultMap="Code">
        <!-- 引入之前定义的查询代码相关信息的 SQL 片段 -->
        <include refid="selectVo"/>
        <!-- 根据学生的唯一标识 student_id 进行筛选 -->
        WHERE c.student_id = #{studentId}
    </select>

    <update id="updateById" parameterType="com.mc.escommon.entity.exam.Code">
        <!-- 指定要更新的表为 code -->
        UPDATE code
        <!-- 使用 set 标签动态生成要更新的字段 -->
        <set>
            <!-- 如果 studentId 不为空，则更新该字段 -->
            <if test="studentId != null">
                student_id = #{studentId},
            </if>
            <!-- 如果 time 不为空，则更新该字段 -->
            <if test="time != null">
                time = #{time},
            </if>
            <!-- 如果 title 不为空且不为空字符串，则更新该字段 -->
            <if test="title != null and title != ''">
                title = #{title},
            </if>
            <!-- 如果 type 不为空，则更新该字段 -->
            <if test="type != null">
                type = #{type},
            </if>
            <!-- 如果 codeMessage 不为空且不为空字符串，则更新该字段 -->
            <if test="codeMessage != null and codeMessage != ''">
                codeMessage = #{codeMessage},
            </if>
            <!-- 如果 runMessage 不为空且不为空字符串，则更新该字段 -->
            <if test="runMessage != null and runMessage != ''">
                runMessage = #{runMessage},
            </if>
        </set>
        <!-- 根据代码的唯一标识 id 来确定要更新的记录 -->
        WHERE id = #{id}
    </update>
</mapper>