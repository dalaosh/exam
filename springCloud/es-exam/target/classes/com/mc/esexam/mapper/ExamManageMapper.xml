<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.mc.esexam.mapper.ExamManageMapper">
    <resultMap id="ExamManage" type="com.mc.escommon.entity.exam.ExamManage">
        <!-- 映射 ExamManage 实体类自身的属性 -->
        <result property="id" column="id"/>
        <result property="description" column="description"/>
        <result property="courseId" column="course_id"/>
        <result property="examDate" column="exam_date"/>
        <result property="totalTime" column="total_time"/>
        <result property="totalScore" column="total_score"/>
        <result property="type" column="type"/>
        <result property="tips" column="tips"/>
        <result property="publicKeys" column="public_keys"/>
        <result property="beginTime" column="begin_time"/>
        <result property="endTime" column="end_time"/>
        <result property="isMarked" column="is_marked"/>
        <result property="isSubmit" column="is_submit"/>

        <!-- 关联映射 Course 对象的属性 -->
        <association property="course" javaType="com.mc.escommon.entity.exam.Course">
            <!-- 映射 Course 实体类自身的属性 -->
            <result property="id" column="course_id"/>
            <result property="teacherId" column="teacher_id"/>
            <result property="name" column="course_name"/>
            <result property="beginTime" column="course_begin_time"/>
            <result property="endTime" column="course_end_time"/>
            <result property="photo" column="course_photo"/>
            <result property="number" column="number"/>
            <result property="message" column="message"/>
        </association>

        <!-- 关联映射 Teacher 对象的属性 -->
        <association property="teacher" javaType="com.mc.escommon.entity.user.Teacher">
            <result property="id" column="teacher_id"/>
            <result property="role" column="role"/>
            <result property="photo" column="teacher_photo"/>
            <result property="account" column="account"/>
            <result property="password" column="password"/>
            <result property="keySm3" column="key_sm3"/>
            <result property="email" column="email"/>
            <result property="name" column="teacher_name"/>
            <result property="sex" column="sex"/>
            <result property="phone" column="phone"/>
            <result property="publicKey" column="public_key"/>
        </association>
    </resultMap>

    <sql id="selectVo">
        SELECT
            em.id,
            em.description,
            em.course_id,
            em.exam_date,
            em.total_time,
            em.total_score,
            em.type,
            em.tips,
            em.public_keys,
            em.begin_time,
            em.end_time,
            em.is_marked,
            em.is_submit,
            c.id AS course_id,
            c.teacher_id,
            c.name AS course_name,
            c.begin_time AS course_begin_time,
            c.end_time AS course_end_time,
            c.photo AS course_photo,
            c.number,
            c.message,
            t.id AS teacher_id,
            t.role,
            t.photo AS teacher_photo,
            t.account,
            t.password,
            t.key_sm3,
            t.email,
            t.name AS teacher_name,
            t.sex,
            t.phone,
            t.public_key
        FROM
            exam_manage em
                LEFT JOIN
            course c ON em.course_id = c.id
                LEFT JOIN
            teacher t ON c.teacher_id = t.id
    </sql>

    <insert id="insert" parameterType="com.mc.escommon.entity.exam.ExamManage" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO exam_manage
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="description != null and description != ''">description,</if>
            <if test="courseId != null">course_id,</if>
            <if test="examDate != null">exam_date,</if>
            <if test="totalTime != null">total_time,</if>
            <if test="totalScore != null">total_score,</if>
            <if test="type != null and type != ''">type,</if>
            <if test="tips != null and tips != ''">tips,</if>
            <if test="publicKeys != null and publicKeys != ''">public_keys,</if>
            <if test="beginTime != null and beginTime != ''">begin_time,</if>
            <if test="endTime != null and endTime != ''">end_time,</if>
            <if test="isMarked != null and isMarked != ''">is_marked,</if>
            <if test="isSubmit != null and isSubmit != ''">is_submit</if>
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="description != null and description != ''">#{description},</if>
            <if test="courseId != null">#{courseId},</if>
            <if test="examDate != null">#{examDate},</if>
            <if test="totalTime != null">#{totalTime},</if>
            <if test="totalScore != null">#{totalScore},</if>
            <if test="type != null and type != ''">#{type},</if>
            <if test="tips != null and tips != ''">#{tips},</if>
            <if test="publicKeys != null and publicKeys != ''">#{publicKeys},</if>
            <if test="beginTime != null and beginTime != ''">#{beginTime},</if>
            <if test="endTime != null and endTime != ''">#{endTime},</if>
            <if test="isMarked != null and isMarked != ''">#{isMarked},</if>
            <if test="isSubmit != null and isSubmit != ''">#{isSubmit}</if>
        </trim>
    </insert>

    <!-- 单个删除 -->
    <delete id="deleteById" parameterType="int">
        DELETE FROM exam_manage WHERE id = #{id}
    </delete>

    <!-- 批量删除 -->
    <delete id="deleteByIds" parameterType="int[]">
        DELETE FROM exam_manage WHERE id IN
        <foreach collection="array" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="selectAll" parameterType="com.mc.escommon.entity.exam.ExamManage" resultMap="ExamManage">
        <!-- 引入之前定义的 SQL 片段 -->
        <include refid="selectVo"/>
        <!-- 使用 where 标签来动态生成 WHERE 子句 -->
        <where>
            <!-- 判断 id 是否不为空，如果不为空则添加对应的查询条件 -->
            <if test="id != null">
                AND em.id = #{id} <!-- 使用表别名 em 引用 id 列 -->
            </if>
            <!-- 判断 description 是否不为空且不为空字符串，如果满足条件则添加对应的查询条件 -->
            <if test="description != null and description != ''">
                AND em.description = #{description} <!-- 使用表别名 em 引用 description 列 -->
            </if>
            <!-- 判断 courseId 是否不为空，如果不为空则添加对应的查询条件 -->
            <if test="courseId != null">
                AND em.course_id = #{courseId} <!-- 使用表别名 em 引用 course_id 列 -->
            </if>
            <!-- 判断 examDate 是否不为空，如果不为空则添加对应的查询条件 -->
            <if test="examDate != null">
                AND em.exam_date = #{examDate} <!-- 使用表别名 em 引用 exam_date 列 -->
            </if>
            <!-- 判断 totalTime 是否不为空，如果不为空则添加对应的查询条件 -->
            <if test="totalTime != null">
                AND em.total_time = #{totalTime} <!-- 使用表别名 em 引用 total_time 列 -->
            </if>
            <!-- 判断 totalScore 是否不为空，如果不为空则添加对应的查询条件 -->
            <if test="totalScore != null">
                AND em.total_score = #{totalScore} <!-- 使用表别名 em 引用 total_score 列 -->
            </if>
            <!-- 判断 type 是否不为空且不为空字符串，如果满足条件则添加对应的查询条件 -->
            <if test="type != null and type != ''">
                AND em.type = #{type} <!-- 使用表别名 em 引用 type 列 -->
            </if>
            <!-- 判断 tips 是否不为空且不为空字符串，如果满足条件则添加对应的查询条件 -->
            <if test="tips != null and tips != ''">
                AND em.tips = #{tips} <!-- 使用表别名 em 引用 tips 列 -->
            </if>
            <!-- 判断 publicKeys 是否不为空且不为空字符串，如果满足条件则添加对应的查询条件 -->
            <if test="publicKeys != null and publicKeys != ''">
                AND em.public_keys = #{publicKeys} <!-- 使用表别名 em 引用 public_keys 列 -->
            </if>
            <if test="teacherId != null">
                AND c.teacher_id = #{teacherId} <!-- 使用表别名 em 引用 public_keys 列 -->
            </if>
            <if test="beginTime != null and beginTime != ''">
                AND em.begin_time = #{beginTime}
            </if>
            <if test="endTime != null and endTime != ''">
                AND em.end_time = #{endTime}
            </if>
            <if test="isMarked != null and isMarked != ''">
                AND em.is_marked = #{isMarked}
            </if>
            <if test="isSubmit != null and isSubmit != ''">
                AND em.is_submit = #{isSubmit}
            </if>
        </where>
        ORDER BY em.exam_date DESC
    </select>

    <select id="selectById" parameterType="int" resultMap="ExamManage">
        <!-- 引入之前定义的查询考试管理相关信息的 SQL 片段 -->
        <include refid="selectVo"/>
        <!-- 根据考试管理的唯一标识 id 进行筛选 -->
        WHERE em.id = #{id}
        ORDER BY em.exam_date DESC
    </select>

    <select id="selectByCourseId" parameterType="int" resultMap="ExamManage">
        <!-- 引入之前定义的查询考试管理相关信息的 SQL 片段 -->
        <include refid="selectVo"/>
        <!-- 根据课程的唯一标识 courseId 进行筛选 -->
        WHERE em.course_id = #{courseId}
    </select>

    <update id="updateById" parameterType="com.mc.escommon.entity.exam.ExamManage">
        <!-- 指定要更新的表为 exam_manage -->
        UPDATE exam_manage
        <!-- 使用 set 标签动态生成要更新的字段 -->
        <set>
            <!-- 如果 description 不为空且不为空字符串，则更新该字段 -->
            <if test="description != null and description != ''">
                description = #{description},
            </if>
            <!-- 如果 courseId 不为空，则更新该字段 -->
            <if test="courseId != null">
                course_id = #{courseId},
            </if>
            <!-- 如果 examDate 不为空，则更新该字段 -->
            <if test="examDate != null">
                exam_date = #{examDate},
            </if>
            <!-- 如果 totalTime 不为空，则更新该字段 -->
            <if test="totalTime != null">
                total_time = #{totalTime},
            </if>
            <!-- 如果 totalScore 不为空，则更新该字段 -->
            <if test="totalScore != null">
                total_score = #{totalScore},
            </if>
            <!-- 如果 type 不为空且不为空字符串，则更新该字段 -->
            <if test="type != null and type != ''">
                type = #{type},
            </if>
            <!-- 如果 tips 不为空且不为空字符串，则更新该字段 -->
            <if test="tips != null and tips != ''">
                tips = #{tips},
            </if>
            <!-- 如果 publicKeys 不为空且不为空字符串，则更新该字段 -->
            <if test="publicKeys != null and publicKeys != ''">
                public_keys = #{publicKeys},
            </if>
            <if test="beginTime != null and beginTime != ''">
                begin_time = #{beginTime},
            </if>
            <if test="endTime != null and endTime != ''">
                end_time = #{endTime},
            </if>
            <if test="isMarked != null and isMarked != ''">
                is_marked = #{isMarked},
            </if>
            <if test="isSubmit != null and isSubmit != ''">
                is_submit = #{isSubmit},
            </if>
        </set>
        <!-- 根据考试管理的唯一标识 id 来确定要更新的记录 -->
        WHERE id = #{id}
    </update>
</mapper>