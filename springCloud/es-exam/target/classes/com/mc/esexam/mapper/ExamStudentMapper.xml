<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mc.esexam.mapper.ExamStudentMapper">
    <resultMap id="ExamStudent" type="com.mc.escommon.entity.exam.ExamStudent">
        <!-- 映射 ExamStudent 实体类自身的属性 -->
        <result property="id" column="id"/>
        <result property="examId" column="exam_id"/>
        <result property="studentId" column="student_id"/>
        <result property="isSubmit" column="is_submit"/>
        <result property="facePath" column="face_path"/>
        <result property="faceSubmit" column="face_submit"/>

        <!-- 关联映射 ExamManage 对象的属性 -->
        <association property="examManage" javaType="com.mc.escommon.entity.exam.ExamManage">
            <!-- 映射 ExamManage 实体类自身的属性 -->
            <result property="id" column="exam_manage_id"/>
            <result property="description" column="description"/>
            <result property="courseId" column="course_id"/>
            <result property="examDate" column="exam_date"/>
            <result property="totalTime" column="total_time"/>
            <result property="totalScore" column="total_score"/>
            <result property="type" column="type"/>
            <result property="tips" column="tips"/>
            <result property="publicKeys" column="public_keys"/>
            <result property="beginTime" column="em_begin_time"/>
            <result property="endTime" column="em_end_time"/>
            <result property="isMarked" column="em_is_marked"/>
        </association>

        <!-- 关联映射 Course 对象的属性 -->
        <association property="course" javaType="com.mc.escommon.entity.exam.Course">
            <!-- 映射 Course 实体类自身的属性 -->
            <result property="id" column="course_id"/>
            <result property="teacherId" column="teacher_id"/>
            <result property="name" column="course_name"/>
            <result property="beginTime" column="begin_time"/>
            <result property="endTime" column="end_time"/>
            <result property="photo" column="course_photo"/>
            <result property="number" column="number"/>
            <result property="message" column="message"/>
        </association>

        <!-- 关联映射 Teacher 对象的属性 -->
        <association property="teacher" javaType="com.mc.escommon.entity.user.Teacher">
            <result property="id" column="teacher_id"/>
            <result property="role" column="role"/>
            <result property="photo" column="teacher_photo"/>
            <result property="account" column="account"/>
            <result property="password" column="password"/>
            <result property="keySm3" column="key_sm3"/>
            <result property="email" column="email"/>
            <result property="name" column="teacher_name"/>
            <result property="sex" column="sex"/>
            <result property="phone" column="phone"/>
            <result property="publicKey" column="public_key"/>
        </association>

        <!-- 关联映射 Student 对象的属性 -->
        <association property="student" javaType="com.mc.escommon.entity.user.Student">
            <id property="id" column="s_id"/>
            <result property="role" column="s_role"/>
            <result property="photo" column="s_photo"/>
            <result property="account" column="s_account"/>
            <result property="password" column="s_password"/>
            <result property="keySm3" column="s_key_sm3"/>
            <result property="email" column="s_email"/>
            <result property="name" column="s_name"/>
            <result property="sex" column="s_sex"/>
            <result property="phone" column="s_phone"/>
            <result property="publicKey" column="s_public_key"/>
        </association>
    </resultMap>

    <sql id="selectVo">
        SELECT
            es.id,
            es.exam_id,
            es.student_id,
            es.is_submit,
            es.face_path,
            es.face_submit,
            em.id AS exam_manage_id,
            em.description,
            em.course_id,
            em.exam_date,
            em.total_time,
            em.total_score,
            em.type,
            em.tips,
            em.public_keys,
            em.is_marked AS em_is_marked,
            em.begin_time AS em_begin_time,
            em.end_time AS em_end_time,
            c.id AS course_id,
            c.teacher_id,
            c.name AS course_name,
            c.begin_time,
            c.end_time,
            c.photo AS course_photo,
            c.number,
            c.message,
            t.id AS teacher_id,
            t.role,
            t.photo AS teacher_photo,
            t.account,
            t.password,
            t.key_sm3,
            t.email,
            t.name AS teacher_name,
            t.sex,
            t.phone,
            t.public_key,
            s.id AS s_id,
            s.role AS s_role,
            s.photo AS s_photo,
            s.account AS s_account,
            s.password AS s_password,
            s.key_sm3 AS s_key_sm3,
            s.email AS s_email,
            s.name AS s_name,
            s.sex AS s_sex,
            s.phone AS s_phone,
            s.public_key AS s_public_key
        FROM
            exam_student es
                LEFT JOIN
            exam_manage em ON es.exam_id = em.id
                LEFT JOIN
            course c ON em.course_id = c.id
                LEFT JOIN
            teacher t ON c.teacher_id = t.id
                LEFT JOIN
            student s ON es.student_id = s.id
    </sql>

    <insert id="insert" parameterType="com.mc.escommon.entity.exam.ExamStudent" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO exam_student
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="examId != null">exam_id,</if>
            <if test="studentId != null">student_id,</if>
            <if test="isSubmit != null">is_submit,</if>
            <if test="facePath != null">face_path,</if>
            <if test="faceSubmit != null">face_submit</if>
        </trim>
        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            <if test="examId != null">#{examId},</if>
            <if test="studentId != null">#{studentId},</if>
            <if test="isSubmit != null">#{isSubmit},</if>
            <if test="facePath != null">#{facePath},</if>
            <if test="faceSubmit != null">#{faceSubmit}</if>
        </trim>
    </insert>

    <!-- 单个删除 -->
    <delete id="deleteById" parameterType="int">
        DELETE FROM exam_student WHERE id = #{id}
    </delete>

    <!-- 批量删除 -->
    <delete id="deleteByIds" parameterType="int[]">
        DELETE FROM exam_student WHERE id IN
        <foreach collection="array" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="selectAll" parameterType="com.mc.escommon.entity.exam.ExamStudent" resultMap="ExamStudent">
        <!-- 引入之前定义的 SQL 片段 -->
        <include refid="selectVo"/>
        <!-- 使用 where 标签来动态生成 WHERE 子句 -->
        <where>
            <!-- 判断 id 是否不为空，如果不为空则添加对应的查询条件 -->
            <if test="id != null">
                AND es.id = #{id} <!-- 使用表别名 es 引用 id 列 -->
            </if>
            <!-- 判断 examId 是否不为空，如果不为空则添加对应的查询条件 -->
            <if test="examId != null">
                AND es.exam_id = #{examId} <!-- 使用表别名 es 引用 exam_id 列 -->
            </if>
            <!-- 判断 studentId 是否不为空，如果不为空则添加对应的查询条件 -->
            <if test="studentId != null">
                AND es.student_id = #{studentId} <!-- 使用表别名 es 引用 student_id 列 -->
            </if>
            <!-- 判断 isSubmit 是否不为空，如果不为空则添加对应的查询条件 -->
            <if test="isSubmit != null">
                AND es.is_submit = #{isSubmit} <!-- 使用表别名 es 引用 is_submit 列 -->
            </if>
            <!-- 判断 facePath 是否不为空，如果不为空则添加对应的查询条件 -->
            <if test="facePath != null">
                AND es.face_path = #{facePath} <!-- 使用表别名 es 引用 face_path 列 -->
            </if>
            <!-- 判断 faceSubmit 是否不为空，如果不为空则添加对应的查询条件 -->
            <if test="faceSubmit != null">
                AND es.face_submit = #{faceSubmit} <!-- 使用表别名 es 引用 face_submit 列 -->
            </if>
            <if test="courseId != null">
                AND c.id= #{courseId} <!-- 使用表别名 es 引用 face_submit 列 -->
            </if>
            <if test="type != null">
                AND c.type = #{type} <!-- 使用表别名 es 引用 face_submit 列 -->
            </if>
        </where>
        ORDER BY es.id DESC
    </select>

    <select id="selectById" parameterType="int" resultMap="ExamStudent">
        <!-- 引入之前定义的查询考试学生相关信息的 SQL 片段 -->
        <include refid="selectVo"/>
        <!-- 根据考试学生的唯一标识 id 进行筛选 -->
        WHERE es.id = #{id}
        <!-- 按照 id 降序排序 -->
        ORDER BY es.id DESC
    </select>

    <update id="updateById" parameterType="com.mc.escommon.entity.exam.ExamStudent">
        <!-- 指定要更新的表为 exam_student -->
        UPDATE exam_student
        <!-- 使用 set 标签动态生成要更新的字段 -->
        <set>
            <!-- 如果 examId 不为空，则更新该字段 -->
            <if test="examId != null">
                exam_id = #{examId},
            </if>
            <!-- 如果 studentId 不为空，则更新该字段 -->
            <if test="studentId != null">
                student_id = #{studentId},
            </if>
            <!-- 如果 isSubmit 不为空，则更新该字段 -->
            <if test="isSubmit != null">
                is_submit = #{isSubmit},
            </if>
            <!-- 如果 facePath 不为空，则更新该字段 -->
            <if test="facePath != null">
                face_path = #{facePath},
            </if>
            <!-- 如果 faceSubmit 不为空，则更新该字段 -->
            <if test="faceSubmit != null">
                face_submit = #{faceSubmit},
            </if>
        </set>
        <!-- 根据考试学生的唯一标识 id 来确定要更新的记录 -->
        WHERE id = #{id}
    </update>
</mapper>