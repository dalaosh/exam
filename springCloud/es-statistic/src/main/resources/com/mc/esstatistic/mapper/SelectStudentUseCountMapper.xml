    <select id="selectQuestionByTypeAll" resultType="java.lang.Integer">
        SELECT COUNT(DISTINCT ep.id)
        FROM course_student cs
        INNER JOIN course c ON cs.course_id = c.id                 <!-- 关联学生加入的课程 -->
        INNER JOIN exam_manage em ON em.course_id = c.id           <!-- 获取课程对应的试卷 -->
        INNER JOIN exam_paper ep ON em.id = ep.exam_id             <!-- 关键修正：关联试卷具体题目 -->
        WHERE cs.student_id = #{studentId}
        AND ep.question_type = #{questionType}                   <!-- 按题型过滤 -->
    </select>

    <select id="selectExamNum" resultType="java.lang.Integer">
        SELECT COUNT(1) FROM exam_manage em
        LEFT JOIN course c on c.id = em.course_id
        LEFT JOIN course_student cs on c.id = cs.course_id
        WHERE cs.student_id=#{studentId}
    </select>
    <select id="selectCourseNum" resultType="java.lang.Integer">
        SELECT COUNT(1) FROM course_student
        WHERE student_id=#{studentId}
    </select>
    <select id="selectAnswerNum" resultType="java.lang.Integer">
        SELECT COUNT(1) from exam_answer ea
        where ea.student_id=#{studentId}
    </select>
    <select id="selectScore" parameterType="com.mc.escommon.entity.exam.ExamScore" resultMap="ExamScore">
        <include refid="selectVo"/>
        WHERE es.student_id=#{studentId}
    </select>

</mapper>